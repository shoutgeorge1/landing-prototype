# Google Tag Manager container ID (format: GTM-XXXXXXX)
# Copy this file to .env.local and fill in your real values.
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX

# HubSpot PPC forms (Bakersfield EN/ES landing pages)
NEXT_PUBLIC_HUBSPOT_PORTAL_ID=
NEXT_PUBLIC_HUBSPOT_ENGLISH_FORM_ID=
NEXT_PUBLIC_HUBSPOT_SPANISH_FORM_ID=
