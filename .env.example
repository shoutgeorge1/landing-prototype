# Google Tag Manager container ID (format: GTM-XXXXXXX)
# Copy this file to .env.local and fill in your real values.
# GA4 and other pixels are configured inside this GTM container.
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX

# Google Ads website conversion tag (Click to call fires from trackPhoneClick)
NEXT_PUBLIC_GOOGLE_ADS_AW_ID=AW-18079555023
NEXT_PUBLIC_GOOGLE_ADS_PHONE_CLICK_SEND_TO=AW-18079555023/lfMHCKvIkNEcEM-7gK1D

# HubSpot PPC forms — Bakersfield EN/ES (na2 region)
# Defaults are baked into src/lib/hubspot.ts; override here if needed.
NEXT_PUBLIC_HUBSPOT_PORTAL_ID=242396697
NEXT_PUBLIC_HUBSPOT_REGION=na2
NEXT_PUBLIC_HUBSPOT_ENGLISH_FORM_ID=6dc81a33-35df-4dc4-b20a-ec5e409ed420
NEXT_PUBLIC_HUBSPOT_SPANISH_FORM_ID=d11f9f2c-a1d2-4ae0-84b3-9f602ad03d51
NEXT_PUBLIC_HUBSPOT_ENGLISH_STANDALONE_URL=https://40behl.share-na2.hsforms.com/2bcgaMzXfTcSyCuxeQJ7UIA
NEXT_PUBLIC_HUBSPOT_SPANISH_STANDALONE_URL=https://40behl.share-na2.hsforms.com/20R-fLKHSSuCEs59gKtA9UQ
