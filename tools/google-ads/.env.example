# =============================================================================
# ELA Google Ads API toolkit — copy to .env and fill in (never commit .env)
# =============================================================================

# Required: Google Ads API developer token (from API Center in your MCC)
GOOGLE_ADS_DEVELOPER_TOKEN=

# Required: OAuth Desktop client credentials (from Google Cloud Console)
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=

# Required: generated via scripts/generate_refresh_token.py
GOOGLE_ADS_REFRESH_TOKEN=

# MCC (manager) account used for API login. Digits only — no dashes.
# Placeholder until provided — replace before live API calls that need MCC context.
GOOGLE_ADS_LOGIN_CUSTOMER_ID=REPLACE_WITH_MCC_ID

# Target Employment Law Assist APC account (digits only)
GOOGLE_ADS_CUSTOMER_ID=6769947952

# Prefer proto-plus messages (recommended)
GOOGLE_ADS_USE_PROTO_PLUS=true

# Optional: path to Desktop OAuth client JSON for refresh-token generation
# GOOGLE_ADS_OAUTH_CLIENT_SECRETS_FILE=credentials/client_secret.json

# Confirmed production HubSpot phone (same on LP + Google Ads call assets)
ELA_CALL_TRACKING_PHONE=4246781416

# Optional: default output directory for exports
# ELA_GOOGLE_ADS_OUTPUT_DIR=output
